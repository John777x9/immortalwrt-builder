#!/bin/sh
# Minimal first-boot hardening common to all roles.
# Only necessary functional changes — user sets passwords / wifi / nodes
# via LuCI after flashing.

# --- Firewall: disable hardware/software fastpath + fullcone ---
# REQUIRED for transparent proxy (sing-box / passwall) to work.
# fastpath bypasses nft chains once a flow is established → tproxy misses.
uci -q batch <<EOF
set firewall.@defaults[0].flow_offloading='0'
set firewall.@defaults[0].flow_offloading_hw='0'
set firewall.@defaults[0].fullcone='0'
set firewall.@defaults[0].fullcone6='0'
set firewall.@defaults[0].synflood_protect='1'
commit firewall
EOF

# --- dnsmasq: standard hardening flags only (NO server config — set per role) ---
# Per-role uci-defaults set dhcp.@dnsmasq[0].server.
# NOTE: alphabetic order has 99-bypass-gateway BEFORE 99-common-hardening,
# so this file MUST NOT touch dnsmasq.server.
uci -q batch <<EOF
set dhcp.@dnsmasq[0].noresolv='1'
set dhcp.@dnsmasq[0].rebind_protection='1'
set dhcp.@dnsmasq[0].rebind_localhost='1'
set dhcp.@dnsmasq[0].localservice='1'
set dhcp.@dnsmasq[0].cachesize='2000'
set dhcp.@dnsmasq[0].filter_aaaa='1'
set dhcp.@dnsmasq[0].interface='br-lan'
set dhcp.@dnsmasq[0].domainneeded='1'
commit dhcp
EOF

# --- IPv6: disable on LAN by default (re-enable in LuCI when needed) ---
uci -q batch <<EOF
set network.lan.ipv6='0'
set dhcp.lan.dhcpv6='disabled'
set dhcp.lan.ra='disabled'
set dhcp.lan.ndp='disabled'
commit network
commit dhcp
EOF

exit 0
